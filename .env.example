# Server settings
CLAUDE_PROXY_HOST=0.0.0.0
CLAUDE_PROXY_PORT=8082

# Path to claude CLI binary (auto-detected if empty)
# Linux: usually "claude" or "/usr/local/bin/claude"
# Windows: usually "C:\Users\<user>\AppData\Roaming\npm\claude.cmd"
CLAUDE_PROXY_CLAUDE_BINARY=

# Default model when not specified in request
CLAUDE_PROXY_DEFAULT_MODEL=sonnet

# Optional budget cap per request (USD)
CLAUDE_PROXY_MAX_BUDGET_USD=

# Request timeout in seconds
CLAUDE_PROXY_REQUEST_TIMEOUT=300

# Optional API key to gate access to this proxy (leave empty to disable)
CLAUDE_PROXY_API_KEY=
